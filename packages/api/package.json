{
  "name": "@auxchamp/api",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./game": {
      "default": "./src/game/index.ts"
    },
    "./game/*": {
      "default": "./src/game/*.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@auxchamp/auth": "workspace:*",
    "@auxchamp/db": "workspace:*",
    "@auxchamp/env": "workspace:*",
    "@orpc/client": "catalog:",
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "dotenv": "catalog:",
    "nanoid": "^3.3.11",
    "valibot": "catalog:"
  },
  "devDependencies": {
    "@auxchamp/config": "workspace:*",
    "typescript": "catalog:"
  }
}
