{
  "name": "@auxchamp/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./schema": {
      "default": "./src/schema/index.ts"
    },
    "./schema/*": {
      "default": "./src/schema/*.ts"
    },
    "./schema/game": {
      "default": "./src/schema/game/index.ts"
    },
    "./schema/game/*": {
      "default": "./src/schema/game/*.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit -p tsconfig.json",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@auxchamp/env": "workspace:*",
    "@neondatabase/serverless": "^1.0.2",
    "dotenv": "catalog:",
    "drizzle-orm": "catalog:",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@auxchamp/config": "workspace:*",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.8",
    "typescript": "catalog:"
  }
}
