{
  "name": "auxchamp",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "valibot": "^1.2.0",
      "typescript": "^5",
      "@types/bun": "^1.3.4",
      "@orpc/server": "^1.12.2",
      "@orpc/openapi": "^1.12.2",
      "@orpc/valibot": "^1.12.2",
      "@better-auth/core": "1.5.2",
      "better-auth": "1.5.2",
      "@orpc/client": "^1.12.2",
      "@orpc/contract": "^1.12.2",
      "drizzle-orm": "^0.45.1"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "db:push": "turbo -F @auxchamp/db db:push",
    "db:studio": "turbo -F @auxchamp/db db:studio",
    "db:generate": "turbo -F @auxchamp/db db:generate",
    "db:migrate": "turbo -F @auxchamp/db db:migrate",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@auxchamp/env": "workspace:*",
    "@vercel/speed-insights": "^1.3.1",
    "dotenv": "catalog:"
  },
  "devDependencies": {
    "@auxchamp/config": "workspace:*",
    "@types/bun": "catalog:",
    "lefthook": "^2.0.13",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.1"
}
