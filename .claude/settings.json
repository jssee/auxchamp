{
  "permissions": {
    "allow": [
      "Bash(bun run:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(tk:*)",
      "Bash(tree:*)",
      "WebFetch(domain:github.com)",
      "Bash(agent-browser:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/branch-guard.sh $TOOL_NAME",
            "timeout": 2000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/auto-format.sh $TOOL_NAME $FILE_PATH",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
